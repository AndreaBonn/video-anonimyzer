# Person Anonymizer — Environment Variables
# Copia questo file in .env e personalizza i valori

# Flask secret key (obbligatorio per produzione)
# Genera con: python -c "import os; print(os.urandom(32).hex())"
FLASK_SECRET_KEY=change-me-in-production

# Web server
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
